# Copy this file to .env for local development.
# In production (Render), set these as real environment variables in the
# service's dashboard instead of committing a .env file.

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=swms_simple
DB_PORT=3306

# Shared secret the IoT bin sensors must send as ?key=... when calling
# update_bin.php. Leave unset locally to skip the check; always set it in
# production.
IOT_API_KEY=

# Google Maps JavaScript API key (used by map.php and the dashboard bin map).
# Create one at https://console.cloud.google.com/google/maps-apis and add an
# HTTP referrer restriction for your domain(s) once you have one.
GOOGLE_MAPS_API_KEY=
